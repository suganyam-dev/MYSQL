USE EX;
SELECT * FROM EMP
WHERE BRANCH_ID =(SELECT BRANCH_ID FROM BRANCH WHERE BR_NAME = 'MADURAI');
SELECT * FROM EMP
WHERE SALARY = (SELECT MIN(SALARY) FROM EMP);
SELECT * FROM EMP
WHERE SALARY = (SELECT MAX(SALARY) FROM EMP);

-- EXISTS

SELECT BRANCH_ID, BR_NAME FROM BRANCH;
SELECT BRANCH_ID, BR_NAME FROM BRANCH WHERE EXISTS(SELECT * FROM EMP WHERE JOB_DES = 'DEVELOPER' AND BRANCH.BRANCH_ID = EMP.BRANCH_ID);
SELECT * FROM EMP WHERE JOB_DES = 'DEVELOPER';

-- ANY

SELECT * FROM BRANCH
WHERE BRANCH_ID = ANY(SELECT BRANCH_ID FROM EMP WHERE SALARY > 60000);

-- ALL
SELECT * FROM EMP WHERE BRANCH_ID <> ALL(
SELECT BRANCH_ID FROM BRANCH WHERE BR_NAME IN ('MADURAI','CHENNAI'));
