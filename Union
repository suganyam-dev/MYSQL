USE EX;
CREATE TABLE MADURAI (
    ID INT AUTO_INCREMENT PRIMARY KEY,
    CITY VARCHAR(50),
    AREA VARCHAR(50)
);

CREATE TABLE CHENNAI (
    ID INT AUTO_INCREMENT PRIMARY KEY,
    CITY VARCHAR(50),
    AREA VARCHAR(50)
);
