SELECT * FROM EMPLOYEES;
SELECT  DEPARTMENT, COUNT(NAME)FROM EMPLOYEES GROUP BY DEPARTMENT;
SELECT  DEPARTMENT, COUNT(ID)FROM EMPLOYEES GROUP BY DEPARTMENT;
SELECT  DEPARTMENT, COUNT(NAME)FROM EMPLOYEES GROUP BY DEPARTMENT HAVING COUNT(NAME) > 6;
SELECT  DEPARTMENT, COUNT(NAME)FROM EMPLOYEES GROUP BY DEPARTMENT HAVING COUNT(NAME) > 6 ORDER BY DEPARTMENT;
SELECT  DEPARTMENT, COUNT(NAME)FROM EMPLOYEES  WHERE SALARY > 5000 GROUP BY DEPARTMENT HAVING COUNT(NAME) > 6 ORDER BY DEPARTMENT;
